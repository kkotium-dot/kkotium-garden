  keyword     String   @db.VarChar(120)
  keywordRank Int      @map("keyword_rank")
  insertedAt  DateTime @default(now()) @map("inserted_at")

  @@index([productId], map: "idx_seo_penetration_product")
  @@index([surface], map: "idx_seo_penetration_surface")
  @@map("seo_penetration_logs")
