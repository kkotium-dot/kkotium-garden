generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  level     Int       @default(1)
  exp       Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Platform {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique @db.VarChar(10)
  url         String?
  description String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  suppliers   Supplier[]

  @@map("platforms")
}

model Supplier {
  id                String            @id @default(cuid())
  name              String
  code              String            @unique
  abbr              String            @unique @db.VarChar(4)
  platformId        String?
  platformCode      String            @default("ETC") @db.VarChar(10)
  platformUrl       String?
  contact           String?
  address           String?
  description       String?
  domeggookSellerId          String?           @map("domeggook_seller_id") @db.VarChar(100)
  defaultShippingTemplateId  String?           @map("default_shipping_template_id")
  defaultMargin              Int               @default(30)
  active                     Boolean           @default(true)
  // 2026-06-02 — 공급사별 합배송 속성 (Desktop이 Supabase ALTER 선행, Code는 동기화만)
  bundleCapable              Boolean           @default(false) @map("bundle_capable")
  naverBundleGroupId         String?           @map("naver_bundle_group_id") @db.VarChar(40)
  islandExtraFee             Int?              @map("island_extra_fee")
  jejuExtraFee               Int?              @map("jeju_extra_fee")
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  products                   Product[]
  platform                   Platform?         @relation(fields: [platformId], references: [id])
  shippingTemplates          ShippingTemplate[]
  defaultShippingTemplate    ShippingTemplate? @relation("SupplierDefaultShipping", fields: [defaultShippingTemplateId], references: [id])
  stockProfiles              SupplierStockProfile[]

  @@index([platformCode])
  @@index([platformId])
  @@index([domeggookSellerId], map: "idx_suppliers_domeggook_seller_id")
}

model Product {
  id                      String            @id @default(cuid())
  // G8-ENGINE-Q4: pre-publish legal approval override (e.g. master_pd_verified
  // for operator-confirmed public-domain artwork). Consumed by asset-legal-gate.
  legalApproval           String?
  // 2026-06-02 — 배송 처리 분기 속성. 'NORMAL' = 표준 위탁 / 'ORDER_MADE' = 주문제작
  // (표준 발행 파이프라인에서 분리). Desktop이 Supabase ALTER 선행.
  shippingAttribute       String            @default("NORMAL") @map("shipping_attribute") @db.VarChar(20)
  naver_title             String?
  naver_keywords          String?
  naver_description       String?
  naver_brand             String?
  naver_manufacturer      String?
  naver_origin            String?
  naver_material          String?
  naver_color             String?
  naver_size              String?
  naver_weight            String?
  naver_care_instructions String?
  naver_warranty          String?
  naver_certification     String?
  // Cached last-observed Naver statusType (SALE / SUSPENSION / ...) from the
  // inspect route (live Naver read). Drives applyStatus.publishState accuracy.
  naver_status_type       String?           @map("naver_status_type") @db.VarChar(30)
  // Captured full-res supplier detail image (app-hosted). Two-branch system —
  // resolves the P16 crawl gap (only 330px thumbnails were captured before).
  source_detail_url       String?           @map("source_detail_url")
  naver_tax_type          String?
  naver_gift_wrapping     Boolean           @default(false)
  naver_as_info           String?
  naver_delivery_info     String?
  naver_exchange_info     String?
  naver_refund_info       String?
  naver_min_order         String?
  naver_max_order         String?
  naver_adult_only        Boolean           @default(false)
  naver_parallel_import   Boolean           @default(false)
  naver_custom_option_1   String?
  naver_custom_option_2   String?
  naver_custom_option_3   String?
  naver_meta_tags         String?
  seo_title               String?
  seo_keywords            String?
  seo_description         String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  additionalImages        Json?
  aiGeneratedDesc         String?
  aiGeneratedTags         Json?
  aiGeneratedTitle        String?
  aiScore                 Int?
  asInfo                  String            @default("평일 10:00~18:00")
  asPhone                 String            @default("고객센터 문의")
  barcode                 String?
  brand                   String            @default("꽃틔움")
  category                String?
  courierCode             String            @default("CJGLS")
  description             String?
  exchangeShippingFee     Int               @default(6000)
  freeShippingMinPrice    Int               @default(30000)
  freeShippingThreshold   Int?
  shippingFee             Int               @default(3000)
  shippingMethod          String            @default("택배배송")
  shippingPayType         String            @default("선결제")
  shippingStrategy        String            @default("무료배송")
  shippingType            String            @default("일반배송")
  returnShippingFee       Int               @default(3000)
  supplierReturnFee       Int               @default(0)
  supplierShippingFee     Int               @default(3000)
  hasOptions              Boolean           @default(false)
  optionName              String?
  optionType              String?
  optionValues            Json?
  options                 Json?
  hookPhrase              String?
  internalNote            String?
  internalTags            Json?
  keywords                Json?
  lastSaleDate            DateTime?
  mainImage               String?
  images                  String[]          @default([])
  imageAltTexts           String[]          @default([])
  imageCount              Int               @default(0)
  manufacturer            String            @default("도매매 공급사")
  margin                  Float
  minorPurchase           String            @default("Y")
  name                    String
  naverCategoryCode       String            @default("50003307")
  naverProductId          String?
  originCode              String            @default("0001")
  productInfoManufacturer String?
  productInfoModel        String?
  productInfoName         String?
  productStatus           String            @default("신상품")
  salesCount              Int               @default(0)
  salePrice               Int
  sellerCode              String?
  seoTitle                String?
  sku                     String            @unique
  status                  String            @default("DRAFT")
  supplierPrice           Int
  tags                    Json?
  targetKeywords          Json?
  taxType                 String            @default("과세")
  vendorCode              String?
  supplierId              String
  userId                  String
  sellerProductCode       String?           @unique
  seller_product_code     String?           @unique @db.VarChar(100)
  supplier_product_code   String?           @db.VarChar(100)
  category_id             String?
  origin_id               String?
  importer_name           String?           @db.VarChar(100)
  instant_discount        Decimal?          @db.Decimal(10, 2)
  shipping_method         String?           @default("parcel") @db.VarChar(50)
  shipping_fee_type       String?           @default("paid") @db.VarChar(50)
  carrier_code            String?           @db.VarChar(50)
  shipping_template_id    String?
  main_image_url          String?
  detail_image_url        String?
  aeo_content             Json?
  aeo_generated_at        DateTime?
  seo_hook_text           String?
  golden_keyword_score    Int?
  return_care_enabled     Boolean           @default(false) @map("return_care_enabled")
  // 2026-06-03 — Concept preset system (docs/design/CONCEPT_PRESET_SYSTEM.md §6-A).
  // Detail-page concept layer; orthogonal to SEO columns (spec §7). Literals are
  // defined in src/lib/design/concept-presets.ts. Desktop applies the Supabase
  // ALTER (migration 20260603_add_concept_preset) before this schema reflects it.
  concept_preset          String            @default("kitchen") @map("concept_preset") @db.VarChar(20)
  preset_intensity        String            @default("l1") @map("preset_intensity") @db.VarChar(10)
  preset_overrides        Json?             @map("preset_overrides")
  // 2026-06-09 — Representative-image finishing (C-7/C-3, REPRESENTATIVE_IMAGE_FINISHING_SYSTEM §3.3).
  // Additional-image slot URLs (composite/mood/lifestyle subcuts; NOT the white-bg
  // representative). DB default '[]'::jsonb. Desktop applies MIGRATION_c7_extra_images
  // (ADD COLUMN IF NOT EXISTS) — idempotent / shared with C-3. apply-composite
  // appends to it behind a P2022 guard so the route is safe before the migration.
  extra_images            Json?             @map("extra_images")
  // 2026-06-09 — C-4 representative-image policy override (REPRESENTATIVE_IMAGE_FINISHING_SYSTEM §4).
  // 'lifestyle_intended' = the operator keeps a non-white-bg representative
  // (e.g. myeonghwa leather): seo-guard white_bg fail downgrades to info and the
  // action queue stops surfacing the finish-representative step. Desktop applies
  // MIGRATION_c4_main_image_policy (ADD COLUMN IF NOT EXISTS) — shared with C-3.
  main_image_policy       String?           @map("main_image_policy") @db.VarChar(30)
  // 2026-06-12 — Product Fidelity Card (docs/design/ADAPTIVE_COMPOSITE_ENGINE.md §11).
  // Per-product reality anchor consumed by the image-prompt builder (promptInject
  // prepend + decorForbidden negatives) and the pre-publish fidelity-check gate
  // (#56). Shape = ProductFidelity (src/lib/fidelity/product-fidelity.ts). Desktop/
  // Code applies MIGRATION_fidelity (ADD COLUMN IF NOT EXISTS) — idempotent;
  // consumers guard P2022/P2021 so routes are safe before the migration lands.
  fidelity                Json?             @map("fidelity")
  // 2026-06-07 — Adaptive 3-mode system (docs/research/KKOTIUM_ADAPTIVE_SEO_IMAGE_SYSTEM_2026-06-06.md §5).
  // The quality classifier writes quality_score(0-100) + recommended_mode; the
  // operator can override the mode from the control tower. brand_line splits the
  // SEO/image templates (seed = low-involvement, greenhouse = high-involvement).
  // Index-only data columns (no Prisma relation); DB CHECK enforces the enums —
  // same String-enum precedent as backdrop_jobs/asset_jobs. Desktop applies the
  // Supabase migration (MIGRATION_phase3_adaptive_mode) before this reflects.
  brand_line              String?           @map("brand_line") @db.VarChar(20)        // SEED | GREENHOUSE
  quality_score           Int?              @map("quality_score")                     // 0-100
  recommended_mode        String?           @map("recommended_mode") @db.VarChar(20)  // SIMPLE | ENHANCE | NEW
  quality_reasons         Json?             @map("quality_reasons")
  orderItems              OrderItem[]
  supplier                Supplier          @relation(fields: [supplierId], references: [id])
  user                    User              @relation(fields: [userId], references: [id])
  naver_categories        NaverCategory?    @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "fk_products_category")
  origin_codes            OriginCode?       @relation(fields: [origin_id], references: [id], onUpdate: NoAction, map: "fk_products_origin")
  shipping_templates      ShippingTemplate? @relation(fields: [shipping_template_id], references: [id], onUpdate: NoAction, map: "fk_products_shipping_template")
  product_options         product_options?
  inventorySnapshots      InventorySnapshot[]
  lowStockAlerts          LowStockAlert[]
  priceMovementAlerts     PriceMovementAlert[]
  competitorSnapshots     CompetitorSnapshot[]
  diagnosis               Diagnosis?

  @@index([supplierId])
  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([imageCount])
  @@index([category_id], map: "idx_products_category_id")
  @@index([origin_id], map: "idx_products_origin_id")
  @@index([seller_product_code], map: "idx_products_seller_code")
  @@index([shipping_template_id], map: "idx_products_shipping_template")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String
  totalAmount     Int
  status          String      @default("PENDING")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  adminMemo       String?
  cancelledAt     DateTime?
  courierCompany  String?
  deliveredAt     DateTime?
  paidAt          DateTime?
  shippedAt       DateTime?
  shippingRequest String?     @default("")
  trackingNumber  String?
  discount        Int?        @default(0)
  paymentMethod   String?
  shippingFee     Int?        @default(0)
  shippingZipcode String?     @default("")
  totalPrice      Int?
  userId          String?
  // Naver order detail fields
  productName     String?     @map("product_name")
  productId       String?     @map("product_id")
  quantity        Int?        @default(1)
  paymentDate     DateTime?   @map("payment_date")
  claimReason     String?     @map("claim_reason")
  claimDetail     String?     @map("claim_detail")
  refundStatus    String?     @map("refund_status")
  orderItems      OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int
  price     Int
  orderId   String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model NaverCategory {
  id           String    @id @default(cuid())
  categoryCode String    @unique @map("category_code")
  depth1       String?
  depth2       String?
  depth3       String?
  depth4       String?
  fullPath     String    @map("full_path")
  createdAt    DateTime  @default(now()) @map("created_at")
  Product      Product[]

  @@index([categoryCode])
  @@map("naver_categories")
}

model OriginCode {
  id         String    @id @default(cuid())
  originCode String    @unique @map("origin_code")
  originName String    @map("origin_name")
  createdAt  DateTime  @default(now()) @map("created_at")
  Product    Product[]

  @@index([originCode])
  @@map("origin_codes")
}

model ShippingTemplate {
  id              String     @id @default(cuid())
  name            String
  code            String     @unique
  platformCode    String?    @map("platform_code")
  supplierCode    String?    @map("supplier_code")
  supplierId      String?    @map("supplier_id")
  isPrimary       Boolean    @default(false) @map("is_primary")
  courierCode     String     @default("CJGLS") @map("courier_code")
  shippingType    Int        @default(1) @map("shipping_type")
  shippingFee     Int        @default(3000) @map("shipping_fee")
  freeThreshold   Int?       @map("free_threshold")
  returnFee       Int        @default(6000) @map("return_fee")
  exchangeFee     Int        @default(6000) @map("exchange_fee")
  jejuFee         Int        @default(5000) @map("jeju_fee")
  islandFee       Int        @default(5000) @map("island_fee")
  naverTemplateNo String?    @map("naver_template_no")
  bundleKey       String?    @map("bundle_key")
  memo            String?
  active          Boolean    @default(true)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  Product         Product[]
  supplier        Supplier?  @relation(fields: [supplierId], references: [id])
  defaultForSuppliers Supplier[] @relation("SupplierDefaultShipping")

  @@index([supplierId], map: "idx_shipping_templates_supplier")
  @@map("shipping_templates")
}

model daily_recommendations {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date         DateTime  @db.Date
  product_name String    @db.VarChar(255)
  supplier_id  String?
  honey_score  Int
  season_tag   String?   @db.VarChar(50)
  status       String?   @default("pending") @db.VarChar(20)
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  @@index([date], map: "idx_daily_recommendations_date")
  @@index([status], map: "idx_daily_recommendations_status")
}

model StoreSettings {
  id                    String   @id @default("default")
  freeShippingThreshold Int      @default(30000) @map("free_shipping_threshold")
  storeName             String   @default("") @map("store_name")
  asPhone               String   @default("") @map("as_phone")
  asGuide               String   @default("") @map("as_guide")
  defaultCourierCode    String   @default("CJGLS") @map("default_courier_code")
  defaultReturnFee      Int      @default(6000) @map("default_return_fee")
  defaultExchangeFee    Int      @default(6000) @map("default_exchange_fee")
  domeggookApiKey       String   @default("") @map("domeggook_api_key")
  // E-2A: Manual review tracking (Naver review API not supported)
  manualReviewCount     Int      @default(0) @map("manual_review_count")
  reviewChecklist       Json     @default("{}") @map("review_checklist")
  reviewLastUpdated     DateTime @default(now()) @map("review_last_updated")
  // E-13A: Kakao business channel (single source of truth)
  kakaoChannelId        String   @default("_xkfALG") @map("kakao_channel_id") @db.VarChar(20)
  kakaoChannelUrl       String   @default("") @map("kakao_channel_url") @db.VarChar(200)
  kakaoChannelName      String   @default("꽃틔움 KKOTIUM") @map("kakao_channel_name") @db.VarChar(100)
  kakaoChannelEmail     String   @default("kkotium@naver.com") @map("kakao_channel_email") @db.VarChar(100)
  // E-13A: Solapi alimtalk integration (built but inactive until 50+ orders/month)
  solapiApiKey          String   @default("") @map("solapi_api_key") @db.VarChar(200)
  solapiApiSecret       String   @default("") @map("solapi_api_secret") @db.VarChar(200)
  kakaoSenderId         String   @default("") @map("kakao_sender_id") @db.VarChar(100)
  kakaoSenderPhone      String   @default("") @map("kakao_sender_phone") @db.VarChar(20)
  // E-13C: Insert card 4-slot color palette (HEX codes)
  insertCardPalette     Json     @default("{\"slot1\":{\"name\":\"Pink\",\"hex\":\"#FF6B8A\"},\"slot2\":{\"name\":\"Red\",\"hex\":\"#E62310\"},\"slot3\":{\"name\":\"Beige\",\"hex\":\"#A37B4B\"},\"slot4\":{\"name\":\"Blush\",\"hex\":\"#D4537E\"}}") @map("insert_card_palette")
  releaseAddressId      String?   @map("release_address_id") @db.VarChar(40)
  returnAddressId       String?   @map("return_address_id") @db.VarChar(40)
  addressbookSyncedAt   DateTime? @map("addressbook_synced_at") @db.Timestamp(6)
  // 2026-06-02 P0 — 공통 콘텐츠 슬롯 4칸 (상품 detailContent 상단·하단 공지)
  noticeTopImageUrl     String?   @map("notice_top_image_url")    @db.VarChar(500)
  noticeTopText         String?   @map("notice_top_text")
  noticeBottomImageUrl  String?   @map("notice_bottom_image_url") @db.VarChar(500)
  noticeBottomText      String?   @map("notice_bottom_text")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("store_settings")
}

model product_options {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id    String    @unique
  option_type   String    @db.VarChar(50)
  option_names  Json?
  option_rows   Json?
  direct_inputs Json?
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
  Product       Product   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_product_options_product")

  @@index([product_id], map: "idx_product_options_product_id")
  @@index([option_type], map: "idx_product_options_type")
}

// Product event log — records state changes for Discord triggers and timeline UI
model ProductEvent {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  type       String   @db.VarChar(50)  // OOS | PRICE_CHANGE | SCORE_DROP | STATUS_CHANGE
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([productId], map: "idx_product_events_product")
  @@index([type], map: "idx_product_events_type")
  @@index([createdAt(sort: Desc)], map: "idx_product_events_created")
  @@map("product_events")
}

model CrawlLog {
  id             String   @id @default(uuid())
  url            String
  name           String?
  supplierPrice  Int      @default(0) @map("supplier_price")
  images         Json     @default("[]")
  options        Json     @default("[]")
  status         String   @default("success")   // success | error
  errorMsg       String?  @map("error_msg")
  source         String   @default("single")    // single | bulk
  sellerNick     String?  @map("seller_nick")
  sellerId       String?  @map("seller_id")
  sellerRank     Int?     @map("seller_rank")
  categoryName   String?  @map("category_name")
  categoryCode   String?  @map("category_code")
  inventory      Int?
  shipFee        Int?     @map("ship_fee")
  canMerge       Boolean? @map("can_merge")
  // Sourcing status: SOURCED → PENDING → REGISTERED
  sourcingStatus String   @default("SOURCED") @map("sourcing_status")
  productId      String?  @map("product_id")   // linked after registration
  crawledAt      DateTime @default(now()) @map("crawled_at")

  @@index([crawledAt(sort: Desc)])
  @@index([sourcingStatus])
  @@index([sellerId])
  @@map("crawl_logs")
}

// ============================================================================
// Sprint 6-A: Inventory Polling Foundation (Option C - Hybrid Dynamic Threshold)
// ============================================================================

// Time-series snapshot of stock data, polled every 6 hours via cron.
// Includes DRAFT products (for pre-registration trend tracking).
// Alerts are only triggered for ACTIVE products (naverProductId IS NOT NULL).
model InventorySnapshot {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String   @map("product_id")
  productNo     String   @map("product_no") @db.VarChar(20)
  qty           Int      @default(0)
  status        String?  @db.VarChar(50)
  minq          Int      @default(1)        // minimum order quantity (>1 means warning for solo seller)
  supplierPrice Int?     @map("supplier_price") // Sprint 6-B: domeggook price.supply captured on same poll. null when not parsed yet.
  isDraft       Boolean  @default(false) @map("is_draft")
  polledAt      DateTime @default(now()) @map("polled_at")
  createdAt     DateTime @default(now()) @map("created_at")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "idx_inv_snap_product")
  @@index([polledAt(sort: Desc)], map: "idx_inv_snap_polled")
  @@index([productId, polledAt(sort: Desc)], map: "idx_inv_snap_product_polled")
  @@index([productNo], map: "idx_inv_snap_product_no")
  @@map("inventory_snapshots")
}

// Sprint 7 P0-B enhancement: DataLab category trend cache. Daily refresh
// from cron-daily; consumed by golden-window-tracker to add market context
// to D+1/3/7 evaluation. trend_score and volume_score both 0..100; market_level
// is the cosmetic bucket ('hot' / 'normal' / 'cold').
model CategoryTrendCache {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cacheKey     String   @unique @map("cache_key") @db.VarChar(120)
  trendScore   Int      @default(0) @map("trend_score")
  volumeScore  Int      @default(0) @map("volume_score")
  marketLevel  String   @default("normal") @map("market_level") @db.VarChar(10)
  dataSource   String   @map("data_source") @db.VarChar(20)
  refreshedAt  DateTime @default(now()) @map("refreshed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([refreshedAt(sort: Desc)], map: "idx_category_trend_cache_refreshed")
  @@map("category_trend_cache")
}

// Sprint 6-E: domeggook category tree cache (refreshed weekly from getCat ver 2.0).
model DomeCategory {
  code        String   @id @db.VarChar(20)
  name        String   @db.VarChar(200)
  depth       Int
  parentCode  String?  @map("parent_code") @db.VarChar(20)
  itemCount   Int      @default(0) @map("item_count")
  refreshedAt DateTime @default(now()) @map("refreshed_at")

  @@index([parentCode], map: "idx_dome_categories_parent")
  @@index([depth], map: "idx_dome_categories_depth")
  @@map("dome_categories")
}

// Sprint 6-E: learned mapping cache (dome category OR product-name hash -> naver path).
// Avoids the per-product Gemini call once a mapping has been seen.
model CategoryMapping {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lookupKey         String    @map("lookup_key") @db.VarChar(120)
  lookupKind        String    @map("lookup_kind") @db.VarChar(20)
  naverD1           String    @map("naver_d1") @db.VarChar(60)
  naverD2           String    @map("naver_d2") @db.VarChar(60)
  naverD3           String    @map("naver_d3") @db.VarChar(60)
  naverD4           String?   @map("naver_d4") @db.VarChar(60)
  naverCategoryCode String?   @map("naver_category_code") @db.VarChar(20)
  confidence        Int       @default(70)
  source            String    @db.VarChar(20)
  hitCount          Int       @default(0) @map("hit_count")
  lastHitAt         DateTime? @map("last_hit_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  @@unique([lookupKind, lookupKey], map: "idx_category_mappings_lookup")
  @@index([lastHitAt(sort: Desc)], map: "idx_category_mappings_last_hit")
  @@map("category_mappings")
}

// Sprint 6-C: competitor snapshots. Per-product per-poll capture of 1-page sellers
// from domeggook getItemList search. Stored as aggregates (median/min/max + count)
// instead of raw seller list to keep volume bounded.
model CompetitorSnapshot {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String    @map("product_id")
  productNo       String    @map("product_no") @db.VarChar(20)
  searchKeyword   String    @map("search_keyword") @db.VarChar(200)
  competitorCount Int       @map("competitor_count")
  minPrice        Int?      @map("min_price")
  maxPrice        Int?      @map("max_price")
  medianPrice     Int?      @map("median_price")
  ourRank         Int?      @map("our_rank")
  ourPrice        Int?      @map("our_price")
  errorNote       String?   @map("error_note") @db.VarChar(200)
  polledAt        DateTime  @default(now()) @map("polled_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "idx_competitor_snapshots_product")
  @@index([polledAt(sort: Desc)], map: "idx_competitor_snapshots_polled")
  @@index([productId, polledAt(sort: Desc)], map: "idx_competitor_snapshots_product_polled")
  @@map("competitor_snapshots")
}

// Sprint 6-B: Price movement alert (mirror of LowStockAlert).
// level: 'yellow' (>=5%), 'orange' (>=10%), 'red' (>=15%) — absolute |delta|.
// direction: 'up' (price increased — margin risk) | 'down' (price decreased — opportunity).
model PriceMovementAlert {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String    @map("product_id")
  level           String    @db.VarChar(10)
  direction       String    @db.VarChar(10)
  baselinePrice   Int       @map("baseline_price")   // 7-day rolling baseline before this snapshot
  currentPrice    Int       @map("current_price")    // snapshot's supplierPrice that triggered
  deltaPct        Float     @map("delta_pct")        // signed percentage delta from baseline
  reason          String?   @db.VarChar(100)
  triggeredAt     DateTime  @default(now()) @map("triggered_at")
  resolvedAt      DateTime? @map("resolved_at")
  resolutionNote  String?   @map("resolution_note") @db.VarChar(200)
  createdAt       DateTime  @default(now()) @map("created_at")
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "idx_price_movement_alerts_product")
  @@index([triggeredAt(sort: Desc)], map: "idx_price_movement_alerts_triggered")
  @@map("price_movement_alerts")
}

// Multi-level alert tracking. Triggered when stock crosses dynamic thresholds.
// level: 'yellow' (caution, dashboard widget only) | 'orange' (warning, Discord) | 'red' (critical, Discord + immediate)
model LowStockAlert {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String    @map("product_id")
  level           String    @db.VarChar(10)
  threshold       Int                                  // computed dynamic threshold at trigger time
  currentQty      Int       @map("current_qty")
  statusReason    String?   @map("status_reason") @db.VarChar(100)
  triggeredAt     DateTime  @default(now()) @map("triggered_at")
  resolvedAt      DateTime? @map("resolved_at")
  resolutionNote  String?   @map("resolution_note") @db.VarChar(200)
  createdAt       DateTime  @default(now()) @map("created_at")
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "idx_low_stock_alerts_product")
  @@index([triggeredAt(sort: Desc)], map: "idx_low_stock_alerts_triggered")
  @@map("low_stock_alerts")
}

// Per-product learned avg daily depletion. Computed from 7-day rolling window.
// Used to derive dynamic thresholds: yellow = D*7, orange = D*3, red = D*1.
// Trustworthy = false when 7+ days of zero variation detected (stale supplier).
model SupplierStockProfile {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productNo           String    @unique @map("product_no") @db.VarChar(20)
  supplierId          String?   @map("supplier_id")
  avgDailyDepletion   Float     @default(0) @map("avg_daily_depletion")
  sampleCount         Int       @default(0) @map("sample_count")
  isTrustworthy       Boolean   @default(true) @map("is_trustworthy")
  lastNoChangeDays    Int       @default(0) @map("last_no_change_days")
  computedAt          DateTime  @default(now()) @map("computed_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  supplier            Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([productNo], map: "idx_supplier_stock_profiles_product_no")
  @@index([supplierId], map: "idx_supplier_stock_profiles_supplier")
  @@map("supplier_stock_profiles")
}

model Diagnosis {
  id                  String   @id @default(cuid())
  productId           String   @unique

  qualityScore        Float
  qualitySignals      Json
  visionComment       String?

  competitionScore    Float
  competitionSamples  Json     @default("[]")

  roiScore            Float
  roiBreakdown        Json     @default("{}")

  conceptTone         Json
  skeletonId          String
  inferenceConfidence Float

  grade               String
  confidenceLevel     String
  recommendedSections String[] @default([])

  pFilterGrade        String?  @map("p_filter_grade")

  diagnosedAt         DateTime @default(now())

  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([grade])
  @@index([skeletonId])
  @@index([pFilterGrade])
}

model LifestyleAsset {
  id           String    @id @default(cuid())
  category     String
  tags         String[]  @default([])
  moodTags     String[]  @default([])
  source       String
  licenseUrl   String?
  storageUrl   String
  width        Int
  height       Int
  colorPalette Json?
  lastUsedAt   DateTime?
  usedBySkus   String[]  @default([])
  createdAt    DateTime  @default(now())

  @@index([category])
  @@index([tags])
  @@index([moodTags])
}

model DarkPatternLintLog {
  id            String   @id @default(cuid())
  productId     String?  @map("product_id")
  blockId       String?  @map("block_id")
  rule          String
  severity      String
  autoFixed     Boolean  @default(false) @map("auto_fixed")
  autoFix       String?  @map("auto_fix")
  sellerMessage String   @map("seller_message")
  context       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([rule])
  @@index([severity])
  @@index([createdAt])
  @@map("dark_pattern_lint_logs")
}

// Sprint 7-M2 5-B — Strategic role signal cache (6h TTL).
// Schema synced from live Supabase columns (Senior MCP created the table
// with `signal_key`, `strategic_role`, `computed_at`, plus identity_* cols).
model StrategySignal {
  id                String   @id @default(cuid())
  productId         String?  @map("product_id")
  signalKey         String   @map("signal_key") @db.VarChar
  searchVolume      Int      @default(0) @map("search_volume")
  productCount      Int      @default(0) @map("product_count")
  opportunityIndex  Float    @default(0) @map("opportunity_index")
  trendSlope        Float    @default(0) @map("trend_slope")
  competitionIdx    String   @default("unknown") @map("competition_idx") @db.VarChar
  honeyScore        Int      @default(0) @map("honey_score")
  strategicRole     String   @map("strategic_role") @db.VarChar
  computedAt        DateTime @default(now()) @map("computed_at")
  identityKeywords  Json?    @map("identity_keywords")
  modifierKeywords  Json?    @map("modifier_keywords")
  primaryIdentity   String?  @map("primary_identity") @db.VarChar
  uniqueSellers     Int?     @map("unique_sellers")

  @@index([productId])
  @@index([signalKey])
  @@index([strategicRole])
  @@index([computedAt])
  @@map("strategy_signals")
}

// Sprint 7-M2 5-B — Art director prompt asset library.
// Schema synced from live Supabase columns (Senior MCP created the table
// with `strategic_role` instead of plain `role`).
model ArtDirectorPrompt {
  id              String   @id @default(cuid())
  productId       String?  @map("product_id")
  categoryHint    String   @map("category_hint")
  conceptAxes     Json     @map("concept_axes")
  prompt          String
  negativePrompt  String?  @map("negative_prompt")
  aspectRatio     String   @default("1:1") @map("aspect_ratio") @db.VarChar
  imageInformed   Boolean  @default(false) @map("image_informed")
  status          String   @db.VarChar
  strategicRole   String?  @map("strategic_role") @db.VarChar
  sellerUsed      Boolean  @default(false) @map("seller_used")
  sellerRating    Int?     @map("seller_rating")
  resultImageUrl  String?  @map("result_image_url")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([categoryHint])
  @@index([status])
  @@index([sellerRating])
  @@map("art_director_prompts")
}

// Phase 1 unmanned backdrop adoption spine (2026-05-30): holds Firefly
// request specs and tracks the ingest+verify lifecycle. status enum is
// enforced by a DB CHECK constraint: pending|generating|classifying|
// uploaded|done|review.
model BackdropJob {
  id              String   @id @default(cuid())
  productId       String   @map("product_id")
  skeletonId      String   @map("skeleton_id")
  baseTone        String   @map("base_tone")
  fireflyRequest  Json     @map("firefly_request")
  status          String   @default("pending")
  outputUrl       String?  @map("output_url")
  storagePath     String?  @map("storage_path")
  error           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@index([productId])
  @@index([status])
  @@map("backdrop_jobs")
}

// ── Phase 1: missing-work-prevention skeleton (asset_jobs state machine +
//    transition log + published-asset provenance) ──
// Authority: docs/research/KKOTIUM_HYBRID_PIPELINE_SYSTEM_DESIGN_2026-06-06.md §4.
// Single source of truth for every asset-pipeline task (image gen/process/
// compose/review/publish). String enums are enforced by DB CHECK constraints
// (see docs/handoff/MIGRATION_phase1_asset_jobs_2026-06-06.sql) — same pattern
// as BackdropJob. New tables only; Product/product_options untouched (no Prisma
// relation to Product, FK kept as an indexed column like BackdropJob).
model AssetJob {
  id              String    @id @default(cuid())
  productId       String    @map("product_id")
  conceptPlanId   String?   @map("concept_plan_id")
  // Phase 2: the specific concept combo (wood/white/car) chosen for a swap.
  conceptComboId  String?   @map("concept_combo_id")
  // lane:    generate | process | compose | review | publish
  lane            String
  // jobType (Phase 1): firefly_generate | remove_bg | color_correct | resize | vectorize
  //          | figma_compose | sharp_composite | mockup | naver_image_upload | naver_publish
  // jobType (Phase 2 product-swap B-plan): product_cutout | mood_bg_generate
  //          | product_composite | harmonize | express_finalize | naver_normalize
  // jobType (Phase 3 adaptive 3-mode chains): quality_assess | thumb_crop
  //          | seo_text | seo_image | bg_swap  (see src/lib/jobs/mode-chains.ts)
  // jobType (Phase 4 crop/edit workflow): region_crop | text_remove
  //          | canvas_expand | bg_clean  (see src/lib/jobs/job-type-routing.ts)
  jobType         String    @map("job_type")
  // tool:    firefly | adobe_express | figma | canva | claude_design | sharp | naver_api
  tool            String
  ipSafe          Boolean   @default(false) @map("ip_safe")
  // status (Phase 1): pending | ready | in_progress | blocked | awaiting_approval | done | failed | cancelled
  // status (Phase 2): + awaiting_human | human_done | review | rejected
  status          String    @default("pending")
  priority        Int       @default(0)
  version         Int       @default(0)
  retryCount      Int       @default(0) @map("retry_count")
  maxRetries      Int       @default(3) @map("max_retries")
  inputRefs       Json?     @map("input_refs")
  outputRefs      Json?     @map("output_refs")
  // C-9 operator intervention cards (migration c9_intervention_fields, 2026-06-11).
  //   interventionType: source_request | hero_crop_request | firefly_drop (null = none)
  //   interventionPayload: dropkit path / prompt / crop guide / source url
  interventionType    String? @map("intervention_type")
  interventionPayload Json?   @map("intervention_payload")
  blockedReason   String?   @map("blocked_reason")
  assignedSession String?   @map("assigned_session")
  heartbeatAt     DateTime? @map("heartbeat_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")
  lastAttemptedAt DateTime? @map("last_attempted_at")

  transitions     AssetJobTransition[]
  references      AssetReference[]

  @@index([productId])
  @@index([status])
  @@index([lane])
  @@map("asset_jobs")
}

// Phase 2: reference assets a job consumes/produces (product cutout, mood bg,
// brand kit, generated candidate). Lets the swap loop track which real-product
// cutout and which AI background fed each composite. New table only.
model AssetReference {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  // assetKind: product_cutout | mood_bg | brand_kit | generated_candidate
  assetKind String   @map("asset_kind")
  assetUrn  String   @map("asset_urn")
  createdAt DateTime @default(now()) @map("created_at")

  job       AssetJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("asset_references")
}

// Append-only transition log: who moved a job from which status to which, when.
model AssetJobTransition {
  id         String   @id @default(cuid())
  jobId      String   @map("job_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  event      String?
  // actor: system | ai_agent | human
  actor      String   @default("system")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  job        AssetJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("asset_job_transitions")
}

// Published asset provenance — locks in the IP source chain of each live image.
model PublishedAsset {
  id            String   @id @default(cuid())
  productId     String   @map("product_id")
  assetUrn      String   @map("asset_urn")
  // role: main | sub | detail
  role          String
  ipProvenance  Json?    @map("ip_provenance")
  naverImageUrl String?  @map("naver_image_url")
  publishedAt   DateTime @default(now()) @map("published_at")

  @@index([productId])
  @@map("published_assets")
}
