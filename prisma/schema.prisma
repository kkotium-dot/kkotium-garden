model DiagnosisResult {
  id        String  @id @default(cuid())
  productId String  @unique @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  c1Category         Float @map("c1_category")
  c2PriceTier        Float @map("c2_price_tier")
  c3RevenuePotential Float @map("c3_revenue_potential")
  c4SourcePoverty    Float @map("c4_source_poverty")
  t1ToneScore        Float @map("t1_tone_score")
  t2Seasonality      Float @map("t2_seasonality")
  t3GiftScore        Float @map("t3_gift_score")
  t4Competition      Float @map("t4_competition")
  t5BrandIdentity    Float @map("t5_brand_identity")

  totalScore          Float  @map("total_score")
  recommendedGrade    String @map("recommended_grade") @db.VarChar(4)
  recommendedSkeleton String @map("recommended_skeleton") @db.VarChar(8)
  reasoning           Json

  diagnosedAt DateTime @default(now()) @map("diagnosed_at")

  @@index([recommendedGrade], map: "idx_diagnosis_result_grade")
  @@index([recommendedSkeleton], map: "idx_diagnosis_result_skeleton")
  @@map("diagnosis_results")
}

model SkeletonTemplate {
  id               String   @id @db.VarChar(8)
  displayName      String   @map("display_name")
  categoryHint     String   @map("category_hint")
  buildingBlockIds Json     @map("building_block_ids")
  sectionCount     Int      @map("section_count")
  estimatedMinutes Int      @map("estimated_minutes")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("skeleton_templates")
}

model BuildingBlock {
  id               String   @id @db.VarChar(8)
  displayName      String   @map("display_name")
  visualRole       String   @map("visual_role")
  seoTargetSurface String   @map("seo_target_surface")
  description      String
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("building_blocks")
}

model SellerOverride {
  id        String  @id @default(cuid())
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  fromGrade    String   @map("from_grade") @db.VarChar(4)
  toGrade      String   @map("to_grade") @db.VarChar(4)
  reasonTag    String   @map("reason_tag") @db.VarChar(40)
  reasonNote   String?  @map("reason_note")
